{
  "name": "tsmarkdown-extension",
  "displayName": "TS markdown",
  "description": "Syntax highlighting and language support for TS markdown files",
  "version": "1.0.5",
  "publisher": "TSMarkdown",
  "icon": "tsmd-logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/andrewtdiz/tsmarkdown-extension"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "tsmarkdown",
    "markdown",
    "typescript",
    "md",
    "mdx",
    "template"
  ],
  "activationEvents": [
    "onLanguage:tsmd"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "activationEvents": [
      "onLanguage:tsmd"
    ],
    "languages": [
      {
        "id": "tsmd",
        "aliases": [
          "TS markdown",
          "tsmarkdown"
        ],
        "extensions": [
          ".tsmd"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./tsmd-logo.png",
          "dark": "./tsmd-logo.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "tsmd",
        "scopeName": "source.tsmd",
        "path": "./syntaxes/tsmd.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "vscode:package": "vsce package --no-dependencies",
    "vscode:publish": "vsce publish --no-dependencies",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.104.0",
    "typescript": "^5.9.2",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "preview": false,
  "dependencies": {}
}