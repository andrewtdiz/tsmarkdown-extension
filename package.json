{
  "name": "tsmarkdown-extension",
  "displayName": "TS markdown Extension",
  "description": "Syntax highlighting and language support for TS markdown files",
  "version": "1.0.0",
  "publisher": "andrewtdiz",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Syntax Highlighters",
    "Snippets"
  ],
  "keywords": [
    "tsmarkdown",
    "markdown",
    "typescript",
    "md",
    "mdx",
    "template"
  ],
  "activationEvents": [
    "onLanguage:tsmd"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "tsmd",
        "aliases": [
          "TS markdown",
          "tsmarkdown"
        ],
        "extensions": [
          ".tsmd"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./tsmd-logo.png",
          "dark": "./tsmd-logo.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "tsmd",
        "scopeName": "text.html.markdown.mdx.tsmd",
        "path": "./syntaxes/tsmd.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "tsmarkdown",
        "path": "./snippets/tsmd.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "vscode:package": "vsce package --no-dependencies",
    "vscode:publish": "vsce publish --no-dependencies",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}