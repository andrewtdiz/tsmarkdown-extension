{
  "displayName": "TypeScript-Markdown",
  "name": "tsmd",
  "scopeName": "source.tsmd",
  "fileTypes": [
    "tsmd"
  ],
  "patterns": [
    {
      "include": "#return-markdown"
    },
    {
      "include": "source.tsx"
    }
  ],
  "repository": {
    "return-markdown": {
      "name": "meta.return.markdown.tsmd",
      "begin": "(\\breturn)(\\s*\\()(?![^\\n]*\\S)",
      "contentName": "text.html.markdown.tsmd",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.return.tsmd"
        },
        "2": {
          "name": "punctuation.section.group.begin.tsmd"
        }
      },
      "applyEndPatternLast": true,
      "end": "(?m:^(\\s*\\))(\\s*[;,])?)",
      "endCaptures": {
        "1": {
          "name": "punctuation.section.group.end.tsmd"
        },
        "2": {
          "name": "punctuation.terminator.statement.tsmd"
        }
      },
      "patterns": [
        {
          "include": "text.html.markdown"
        }
      ]
    }
  }
}
