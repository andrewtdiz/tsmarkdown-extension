{
  "displayName": "TSmd",
  "name": "tsmd",
  "scopeName": "source.tsmd",
  "fileTypes": [
    "tsmd"
  ],
  "patterns": [
    {
      "include": "#return-markdown-block"
    },
    {
      "include": "source.ts"
    }
  ],
  "injections": {
    "meta.return.markdown.tsmd - meta.embedded.block.ts.tsmd": {
      "patterns": [
        {
          "include": "text.html.markdown"
        }
      ]
    },
    "meta.parentheses.markdown.tsmd - meta.embedded.block.ts.tsmd": {
      "patterns": [
        {
          "include": "text.html.markdown"
        }
      ]
    },
    "meta.component.tsmd - meta.embedded.block.ts.tsmd": {
      "patterns": [
        {
          "include": "text.html.markdown"
        }
      ]
    }
  },
  "repository": {
    "return-markdown-block": {
      "name": "meta.return.markdown.tsmd",
      "begin": "(\\breturn)(\\s*)(\\()(?=\\s*(?:\\r?\\n|$))",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.flow.ts"
        },
        "3": {
          "name": "punctuation.section.group.begin.tsmd"
        }
      },
      "end": "\\)(?=\\s*(?:[);,\\]}]|$))",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.group.end.tsmd"
        }
      },
      "contentName": "text.html.markdown",
      "applyEndPatternLast": 1,
      "patterns": [
        {
          "include": "#embedded-typescript"
        },
        {
          "include": "#component-element"
        },
        {
          "include": "#markdown-parentheses"
        }
      ]
    },
    "embedded-typescript": {
      "name": "meta.embedded.block.ts.tsmd",
      "begin": "\\{\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.embedded.begin.tsmd"
        }
      },
      "end": "\\}\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.embedded.end.tsmd"
        }
      },
      "patterns": [
        {
          "include": "source.ts"
        }
      ]
    },
    "component-element": {
      "name": "meta.component.tsmd",
      "begin": "<@([A-Za-z_][A-Za-z0-9_-]*(?:\\.[A-Za-z_][A-Za-z0-9_-]*)*)",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.tag.begin.tsmd"
        },
        "1": {
          "name": "entity.name.tag.component.tsmd"
        }
      },
      "end": "(/>)|(</@([A-Za-z_][A-Za-z0-9_-]*(?:\\.[A-Za-z_][A-Za-z0-9_-]*)*)>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.self-closing.end.tsmd"
        },
        "2": {
          "name": "punctuation.definition.tag.end.tsmd"
        },
        "3": {
          "name": "entity.name.tag.component.tsmd"
        }
      },
      "applyEndPatternLast": 1,
      "contentName": "text.html.markdown",
      "patterns": [
        {
          "include": "#component-attributes"
        },
        {
          "include": "#embedded-typescript"
        },
        {
          "include": "#component-element"
        }
      ]
    },
    "component-attributes": {
      "name": "meta.component.attributes.tsmd",
      "patterns": [
        {
          "name": "entity.other.attribute-name.tsmd",
          "match": "\\b([A-Za-z_][A-Za-z0-9_-]*)\\s*(?==)"
        },
        {
          "name": "string.quoted.double.tsmd",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.tsmd"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.tsmd"
            }
          },
          "patterns": [
            {
              "include": "#embedded-typescript"
            }
          ]
        },
        {
          "name": "string.quoted.single.tsmd",
          "begin": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.tsmd"
            }
          },
          "end": "'",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.tsmd"
            }
          },
          "patterns": [
            {
              "include": "#embedded-typescript"
            }
          ]
        },
        {
          "name": "meta.component.expression.attribute.tsmd",
          "begin": "\\{",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.group.begin.tsmd"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.group.end.tsmd"
            }
          },
          "patterns": [
            {
              "include": "source.ts"
            }
          ]
        }
      ]
    },
    "markdown-parentheses": {
      "name": "meta.parentheses.markdown.tsmd",
      "begin": "\\(",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.group.begin.tsmd"
        }
      },
      "end": "\\)",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.group.end.tsmd"
        }
      },
      "contentName": "text.html.markdown",
      "patterns": [
        {
          "include": "#embedded-typescript"
        },
        {
          "include": "#component-element"
        },
        {
          "include": "#markdown-parentheses"
        }
      ]
    }
  }
}
