{
  "displayName": "TypeScript-Markdown",
  "name": "tsmd",
  "scopeName": "source.tsmd",
  "fileTypes": [
    "tsmd"
  ],
  "patterns": [
    {
      "include": "#tsm-block"
    },
    {
      "include": "source.tsx#directives"
    },
    {
      "include": "source.tsx#statements"
    },
    {
      "include": "source.tsx#shebang"
    },
    {
      "include": "#markdown-heading"
    },
    {
      "include": "#markdown-list"
    },
    {
      "include": "#markdown-ordered-list"
    },
    {
      "include": "#markdown-blockquote"
    },
    {
      "include": "#markdown-code-fence"
    },
    {
      "include": "#markdown-inline-code"
    },
    {
      "include": "#markdown-strong"
    },
    {
      "include": "#markdown-emphasis"
    },
    {
      "include": "#markdown-link"
    },
    {
      "include": "#markdown-image"
    },
    {
      "include": "#comment-block"
    },
    {
      "include": "#comment-line"
    },
    {
      "include": "#decorator"
    },
    {
      "include": "#import-export"
    },
    {
      "include": "#class-declaration"
    },
    {
      "include": "#interface-declaration"
    },
    {
      "include": "#type-alias"
    },
    {
      "include": "#enum-declaration"
    },
    {
      "include": "#function-declaration"
    },
    {
      "include": "#arrow-function"
    },
    {
      "include": "#storage-keyword"
    },
    {
      "include": "#modifier-keyword"
    },
    {
      "include": "#control-keyword"
    },
    {
      "include": "#operator-keyword"
    },
    {
      "include": "#spread-operator"
    },
    {
      "include": "#type-keyword"
    },
    {
      "include": "#type-builtin"
    },
    {
      "include": "#boolean-literal"
    },
    {
      "include": "#number"
    },
    {
      "include": "#string"
    },
    {
      "include": "#template-string"
    },
    {
      "include": "#regex-literal"
    },
    {
      "include": "#type-annotation"
    }
  ],
  "repository": {
    "tsm-block": {
      "name": "meta.tsm-block.tsmd",
      "begin": "(\\breturn\\s+\\(|=>\\s*\\()",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.return.tsmd"
        },
        "2": {
          "name": "storage.type.function.arrow.tsmd"
        }
      },
      "end": "\\)",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.block.end.tsmd"
        }
      },
      "patterns": [
        {
          "include": "#tsm-markdown"
        },
        {
          "include": "#tsm-interpolation"
        },
        {
          "include": "#tsm-component"
        },
        {
          "include": "#tsm-xml-group"
        },
        {
          "include": "#tsm-comment"
        }
      ]
    },
    "tsm-interpolation": {
      "name": "meta.interpolation.tsmd",
      "begin": "\\{\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.interpolation.begin.tsmd"
        }
      },
      "end": "\\}\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.interpolation.end.tsmd"
        }
      },
      "patterns": [
        {
          "include": "#tsm-conditional-block"
        },
        {
          "include": "#tsm-component"
        },
        {
          "include": "#tsm-xml-group"
        },
        {
          "include": "#tsm-comment"
        },
        {
          "include": "#tsm-markdown"
        },
        {
          "include": "#tsm-expression"
        }
      ]
    },
    "tsm-conditional-block": {
      "name": "meta.conditional-block.tsmd",
      "begin": "\\?\\s*\\(",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.conditional.begin.tsmd"
        }
      },
      "end": "\\)",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.conditional.end.tsmd"
        }
      },
      "patterns": [
        {
          "include": "#tsm-interpolation"
        },
        {
          "include": "#tsm-component"
        },
        {
          "include": "#tsm-xml-group"
        },
        {
          "include": "#tsm-comment"
        },
        {
          "include": "#tsm-markdown"
        }
      ]
    },
    "tsm-expression": {
      "patterns": [
        {
          "include": "source.tsx#expression"
        },
        {
          "include": "source.tsx#expression-operators"
        },
        {
          "include": "source.tsx#ternary-expression"
        },
        {
          "include": "source.tsx#function-call"
        },
        {
          "include": "source.tsx#function-declaration"
        },
        {
          "include": "source.tsx#function-expression"
        },
        {
          "include": "source.tsx#arrow-function"
        },
        {
          "include": "source.tsx#import-declaration"
        },
        {
          "include": "source.tsx#export-declaration"
        },
        {
          "include": "source.tsx#class-declaration"
        },
        {
          "include": "source.tsx#interface-declaration"
        },
        {
          "include": "source.tsx#enum-declaration"
        },
        {
          "include": "source.tsx#var-expr"
        },
        {
          "include": "source.tsx#variable-initializer"
        },
        {
          "include": "source.tsx#binding-element"
        },
        {
          "include": "source.tsx#object-literal"
        },
        {
          "include": "source.tsx#array-literal"
        },
        {
          "include": "source.tsx#type-annotation"
        },
        {
          "include": "source.tsx#type-parameters"
        },
        {
          "include": "source.tsx#type-object"
        },
        {
          "include": "source.tsx#template"
        },
        {
          "include": "source.tsx#template-substitution-element"
        },
        {
          "include": "source.tsx#string"
        },
        {
          "include": "source.tsx#numeric-literal"
        },
        {
          "include": "source.tsx#boolean-literal"
        },
        {
          "include": "source.tsx#null-literal"
        },
        {
          "include": "source.tsx#undefined-literal"
        },
        {
          "include": "source.tsx#regex"
        },
        {
          "include": "source.tsx#return-type"
        },
        {
          "include": "source.tsx#control-statement"
        },
        {
          "include": "source.tsx#if-statement"
        },
        {
          "include": "source.tsx#switch-statement"
        },
        {
          "include": "source.tsx#for-loop"
        },
        {
          "include": "source.tsx#comment"
        },
        {
          "include": "source.tsx#docblock"
        },
        {
          "include": "source.tsx#jsx"
        },
        {
          "include": "source.tsx#jsx-tag"
        },
        {
          "include": "source.tsx#jsx-children"
        },
        {
          "include": "source.tsx#jsx-tag-attributes"
        }
      ]
    },
    "tsm-component": {
      "name": "meta.component.tsmd",
      "begin": "<@([A-Za-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.tag.begin.tsmd"
        },
        "1": {
          "name": "entity.name.tag.component.tsmd"
        }
      },
      "end": "(/>)|(</@([A-Za-z_][A-Za-z0-9_]*>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.self-closing.end.tsmd"
        },
        "2": {
          "name": "punctuation.definition.tag.end.tsmd"
        },
        "3": {
          "name": "entity.name.tag.component.tsmd"
        }
      },
      "patterns": [
        {
          "include": "#tsm-component-attributes"
        },
        {
          "include": "#tsm-interpolation"
        },
        {
          "include": "#tsm-component"
        },
        {
          "include": "#tsm-xml-group"
        },
        {
          "include": "#tsm-comment"
        },
        {
          "include": "#tsm-markdown"
        }
      ]
    },
    "tsm-component-attributes": {
      "name": "meta.attributes.tsmd",
      "patterns": [
        {
          "name": "entity.other.attribute-name.tsmd",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*="
        },
        {
          "name": "string.quoted.double.tsmd",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "include": "#tsm-interpolation"
            }
          ]
        },
        {
          "name": "string.quoted.single.tsmd",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "include": "#tsm-interpolation"
            }
          ]
        },
        {
          "name": "meta.attribute-expression.tsmd",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            {
              "include": "#tsm-expression"
            }
          ]
        }
      ]
    },
    "tsm-xml-group": {
      "name": "meta.xml-group.tsmd",
      "begin": "<([A-Za-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.tag.begin.tsmd"
        },
        "1": {
          "name": "entity.name.tag.xml-group.tsmd"
        }
      },
      "end": "(/>)|(</([A-Za-z_][A-Za-z0-9_]*)>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.self-closing.end.tsmd"
        },
        "2": {
          "name": "punctuation.definition.tag.end.tsmd"
        },
        "3": {
          "name": "entity.name.tag.xml-group.tsmd"
        }
      },
      "patterns": [
        {
          "include": "#tsm-component-attributes"
        },
        {
          "include": "#tsm-interpolation"
        },
        {
          "include": "#tsm-component"
        },
        {
          "include": "#tsm-xml-group"
        },
        {
          "include": "#tsm-comment"
        },
        {
          "include": "#tsm-markdown"
        }
      ]
    },
    "tsm-comment": {
      "name": "comment.line.double-slash.tsmd",
      "match": "^\\s*//.*$"
    },
    "tsm-markdown": {
      "patterns": [
        {
          "name": "markup.heading.1.tsmd",
          "match": "^#{1}\\s+(.+)$"
        },
        {
          "name": "markup.heading.2.tsmd",
          "match": "^#{2}\\s+(.+)$"
        },
        {
          "name": "markup.heading.3.tsmd",
          "match": "^#{3}\\s+(.+)$"
        },
        {
          "name": "markup.heading.4.tsmd",
          "match": "^#{4}\\s+(.+)$"
        },
        {
          "name": "markup.heading.5.tsmd",
          "match": "^#{5}\\s+(.+)$"
        },
        {
          "name": "markup.heading.6.tsmd",
          "match": "^#{6}\\s+(.+)$"
        },
        {
          "name": "markup.bold.tsmd",
          "match": "\\*\\*([^*]+)\\*\\*"
        },
        {
          "name": "markup.italic.tsmd",
          "match": "\\*([^*]+)\\*"
        },
        {
          "name": "markup.inline.raw.tsmd",
          "match": "`([^`]+)`"
        },
        {
          "name": "markup.underline.link.tsmd",
          "match": "\\[([^\\]]+)\\]\\(([^)]+)\\)"
        },
        {
          "name": "markup.underline.link.image.tsmd",
          "match": "!\\[([^\\]]*)\\]\\(([^)]+)\\)"
        },
        {
          "name": "markup.list.unnumbered.tsmd",
          "match": "^\\s*[-*+]\\s+(.+)$"
        },
        {
          "name": "markup.list.numbered.tsmd",
          "match": "^\\s*\\d+\\.\\s+(.+)$"
        },
        {
          "name": "markup.quote.tsmd",
          "match": "^\\s*>\\s*(.+)$"
        },
        {
          "name": "markup.raw.block.tsmd",
          "begin": "```",
          "end": "```"
        },
        {
          "name": "markup.raw.block.tsmd",
          "begin": "~~~",
          "end": "~~~"
        },
        {
          "name": "markup.emphasis.quotes.tsmd",
          "match": "\"([^\"]+)\""
        },
        {
          "name": "markup.emphasis.single-quotes.tsmd",
          "match": "'([^']+)'"
        }
      ]
    },
    "comment-block": {
      "patterns": [
        {
          "name": "comment.block.documentation.tsx",
          "begin": "/\\*\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.block.tsx",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "comment-line": {
      "name": "comment.line.double-slash.tsx",
      "match": "//.*$"
    },
    "decorator": {
      "name": "entity.name.function.decorator.tsx",
      "match": "@[A-Za-z_][\\w.]*"
    },
    "import-export": {
      "patterns": [
        {
          "name": "keyword.control.import.tsx",
          "match": "\\b(import|export|from|as|default)\\b"
        }
      ]
    },
    "storage-keyword": {
      "name": "storage.type.variable.tsx",
      "match": "\\b(const|let|var)\\b"
    },
    "modifier-keyword": {
      "name": "storage.modifier.tsx",
      "match": "\\b(public|private|protected|readonly|static|abstract|declare|override|async)\\b"
    },
    "control-keyword": {
      "name": "keyword.control.flow.tsx",
      "match": "\\b(if|else|switch|case|default|for|while|do|break|continue|return|yield|throw|try|catch|finally|await)\\b"
    },
    "operator-keyword": {
      "name": "keyword.operator.tsx",
      "match": "\\b(new|delete|typeof|instanceof|in|of|as|satisfies|keyof|infer)\\b"
    },
    "type-keyword": {
      "name": "storage.type.tsx",
      "match": "\\b(class|interface|type|enum|namespace|module|extends|implements|super|this)\\b"
    },
    "type-builtin": {
      "name": "support.type.primitive.tsx",
      "match": "\\b(string|number|boolean|any|unknown|never|void|null|undefined|object|symbol|bigint)\\b"
    },
    "boolean-literal": {
      "name": "constant.language.boolean.tsx",
      "match": "\\b(true|false)\\b"
    },
    "number": {
      "name": "constant.numeric.tsx",
      "match": "(?<![$\\w])(0[xX][0-9A-Fa-f_]+|0[bB][01_]+|0[oO][0-7_]+|\\d[\\d_]*(\\.\\d[\\d_]*)?([eE][+-]?\\d[\\d_]*)?)(?![$\\w])"
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.tsx",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.tsx"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.tsx"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.tsx",
              "match": "\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.tsx",
          "begin": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.tsx"
            }
          },
          "end": "'",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.tsx"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.tsx",
              "match": "\\."
            }
          ]
        }
      ]
    },
    "template-string": {
      "name": "string.template.tsx",
      "begin": "`",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.tsx"
        }
      },
      "end": "`",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.tsx"
        }
      },
      "patterns": [
        {
          "name": "constant.character.escape.tsx",
          "match": "\\."
        },
        {
          "include": "#template-interpolation"
        }
      ]
    },
    "template-interpolation": {
      "name": "meta.embedded.expression.template.tsx",
      "begin": "\\$\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.embedded.begin.tsx"
        }
      },
      "end": "\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.embedded.end.tsx"
        }
      },
      "patterns": [
        {
          "include": "#comment-block"
        },
        {
          "include": "#comment-line"
        },
        {
          "include": "#string"
        },
        {
          "include": "#template-string"
        },
        {
          "include": "#number"
        },
        {
          "include": "#decorator"
        },
        {
          "include": "#storage-keyword"
        },
        {
          "include": "#modifier-keyword"
        },
        {
          "include": "#control-keyword"
        },
        {
          "include": "#operator-keyword"
        },
        {
          "include": "#type-builtin"
        },
        {
          "include": "#boolean-literal"
        },
        {
          "include": "#function-declaration"
        },
        {
          "include": "#arrow-function"
        },
        {
          "include": "#spread-operator"
        },
        {
          "include": "#type-annotation"
        },
        {
          "include": "#jsx-tag"
        }
      ]
    },
    "regex-literal": {
      "name": "string.regexp.tsx",
      "match": "(?<![\\w$])(\/)(?![/*])(?:\\\/|[^/])+\/(?:[dgimsuy]*)"
    },
    "spread-operator": {
      "name": "keyword.operator.spread.tsx",
      "match": "\\.\\.\\."
    },
    "type-reference": {
      "name": "support.type.tsx",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
    },
    "type-generic": {
      "begin": "<",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.typeparameters.begin.tsx"
        }
      },
      "end": ">",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.typeparameters.end.tsx"
        }
      },
      "patterns": [
        {
          "include": "#type-builtin"
        },
        {
          "include": "#type-reference"
        },
        {
          "include": "#type-operator"
        },
        {
          "include": "#punctuation-comma"
        },
        {
          "include": "#type-generic"
        }
      ]
    },
    "type-operator": {
      "name": "keyword.operator.type.tsx",
      "match": "[&|?]"
    },
    "punctuation-comma": {
      "name": "punctuation.separator.comma.tsx",
      "match": ","
    },
    "type-literal": {
      "name": "meta.type.literal.tsx",
      "begin": "\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.block.begin.tsx"
        }
      },
      "end": "\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.block.end.tsx"
        }
      },
      "patterns": [
        {
          "include": "#comment-line"
        },
        {
          "include": "#comment-block"
        },
        {
          "include": "#string"
        },
        {
          "include": "#number"
        },
        {
          "include": "#type-annotation"
        },
        {
          "include": "#type-reference"
        },
        {
          "include": "#type-builtin"
        },
        {
          "include": "#type-generic"
        },
        {
          "include": "#punctuation-comma"
        }
      ]
    },
    "type-annotation": {
      "name": "meta.type.annotation.tsx",
      "begin": "(:)\\s*",
      "beginCaptures": {
        "1": {
          "name": "keyword.operator.type.annotation.tsx"
        }
      },
      "end": "(?=[,;)=}>]|=>|$)",
      "patterns": [
        {
          "include": "#type-builtin"
        },
        {
          "include": "#type-keyword"
        },
        {
          "include": "#type-reference"
        },
        {
          "include": "#type-generic"
        },
        {
          "include": "#type-operator"
        },
        {
          "include": "#type-literal"
        },
        {
          "include": "#boolean-literal"
        },
        {
          "include": "#number"
        },
        {
          "include": "#string"
        },
        {
          "include": "#comment-line"
        },
        {
          "include": "#comment-block"
        }
      ]
    },
    "class-declaration": {
      "begin": "\\b(class)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": {
          "name": "storage.type.class.tsx"
        },
        "2": {
          "name": "entity.name.type.class.tsx"
        }
      },
      "end": "(?=\\s*\\{)",
      "patterns": [
        {
          "include": "#type-keyword"
        },
        {
          "include": "#type-reference"
        },
        {
          "include": "#type-generic"
        }
      ]
    },
    "interface-declaration": {
      "begin": "\\b(interface)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": {
          "name": "storage.type.interface.tsx"
        },
        "2": {
          "name": "entity.name.type.interface.tsx"
        }
      },
      "end": "(?=\\s*\\{)",
      "patterns": [
        {
          "include": "#type-keyword"
        },
        {
          "include": "#type-reference"
        },
        {
          "include": "#type-generic"
        }
      ]
    },
    "type-alias": {
      "begin": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": {
          "name": "storage.type.alias.tsx"
        },
        "2": {
          "name": "entity.name.type.alias.tsx"
        }
      },
      "end": "(?==)",
      "patterns": [
        {
          "include": "#type-generic"
        }
      ]
    },
    "enum-declaration": {
      "begin": "\\b(enum)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": {
          "name": "storage.type.enum.tsx"
        },
        "2": {
          "name": "entity.name.type.enum.tsx"
        }
